# OpenRouter API Key (primary)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx

# Hugging Face API Key (fallback) - Get from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxx

# Model chain - OpenRouter free models
MODEL_FALLBACK_CHAIN=google/gemini-2.0-flash-lite,meta-llama/llama-3.2-3b-instruct,mistralai/mistral-7b-instruct

# Hugging Face models to try (optional, override if needed)
# HUGGINGFACE_MODELS=google/gemma-2-2b-it,microsoft/phi-2

# App settings
APP_URL=http://localhost:3000
VELARIS_DB_PATH=velaris.db
