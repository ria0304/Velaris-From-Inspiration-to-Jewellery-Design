# OPENROUTER_API_KEY: Required for the Python design engine (main.py / backend/).
# Get one at https://openrouter.ai/keys — a single key gives access to
# Claude, GPT-4o, Gemini, and many other models through one unified API.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# MODEL_FALLBACK_CHAIN: Optional. Comma-separated OpenRouter model slugs,
# tried in order until one succeeds. Defaults to:
#   anthropic/claude-sonnet-4.5,openai/gpt-4o,google/gemini-2.5-flash
# MODEL_FALLBACK_CHAIN="anthropic/claude-sonnet-4.5,openai/gpt-4o,google/gemini-2.5-flash"



# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
